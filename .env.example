# Copy this file to .env and fill in all values before running.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<set-a-strong-password>
POSTGRES_DB=ecommerce
POSTGRES_HOST=localhost   # use "db" when running inside Docker Compose
DB_PORT=5432

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=info
APP_ENV=production        # set to "development" to enable /docs and /redoc

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to disable CORS.
# Example: http://localhost:3000,https://yourshop.com
CORS_ORIGINS=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-long-random-secret>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Default admin (created automatically on first run) ───────────────────────
ADMIN_EMAIL=<your-admin-email>
ADMIN_PASSWORD=<set-a-strong-admin-password>

# Constructed automatically from the above — override only if needed.
# DATABASE_URL=postgresql://postgres:<password>@db:5432/ecommerce
