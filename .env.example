# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce
POSTGRES_HOST=localhost   # use "db" when running inside Docker Compose
DB_PORT=5432

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=info

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Default admin (created automatically on first run) ───────────────────────
ADMIN_EMAIL=admin@jewelry.com
ADMIN_PASSWORD=admin1234

# Constructed automatically from the above — override only if needed.
# DATABASE_URL=postgresql://postgres:postgres@db:5432/ecommerce
