# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ecommerce
DB_PORT=5432

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=8000
LOG_LEVEL=info

